rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // Collections — only the owner can read / write
    // ──────────────────────────────────────────────
    match /collections/{collectionId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;

      // Allow create when there is no existing resource yet
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;

      // ── Requests subcollection ──
      // Same owner check — walk up to the parent collection doc
      match /requests/{requestId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == get(
                                /databases/$(database)/documents/collections/$(collectionId)
                              ).data.userId;
      }
    }

    // ──────────────────────────────────────────────
    // Share Links — public read, authenticated write
    // ──────────────────────────────────────────────
    match /shareLinks/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
